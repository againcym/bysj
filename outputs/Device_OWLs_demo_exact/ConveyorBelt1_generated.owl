<?xml version='1.0' encoding='utf-8'?>
<rdf:RDF xmlns="http://www.semanticweb.org/ontologies/arm1_sm#" xmlns:owl="http://www.w3.org/2002/07/owl#" xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#" xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#" xml:base="http://www.semanticweb.org/ontologies/arm1_sm">
    <owl:Ontology rdf:about="http://www.semanticweb.org/ontologies/arm1_sm" />
    <owl:Class rdf:about="#State" />
    <owl:ObjectProperty rdf:about="#forward_conveyorBelt1">
        <rdfs:label>forward (Q0.0)</rdfs:label>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="#backward_conveyorBelt1">
        <rdfs:label>backward (Q0.1)</rdfs:label>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="#stop_conveyorBelt1">
        <rdfs:label>stop (Q0.2)</rdfs:label>
    </owl:ObjectProperty>
    <owl:NamedIndividual rdf:about="#CB1Stopped">
        <rdf:type rdf:resource="#State" />
        <rdfs:label>stopped | Conveyorbelt1Motor</rdfs:label>
        <forward_conveyorBelt1 rdf:resource="#CB1MovingForward" />
        <backward_conveyorBelt1 rdf:resource="#CB1MovingBackward" />
        <stop_conveyorBelt1 rdf:resource="#CB1Stopped" />
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="#CB1MovingForward">
        <rdf:type rdf:resource="#State" />
        <rdfs:label>forward rotation | Conveyorbelt1Motor</rdfs:label>
        <stop_conveyorBelt1 rdf:resource="#CB1Stopped" />
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="#CB1MovingBackward">
        <rdf:type rdf:resource="#State" />
        <rdfs:label>backward rotation | Conveyorbelt1Motor</rdfs:label>
        <stop_conveyorBelt1 rdf:resource="#CB1Stopped" />
    </owl:NamedIndividual>
</rdf:RDF>