    <!-- ==================== 传送带1 设备 ==================== -->
    <Device name="ConveyorBelt1">
        <Signal Name="Conveyorbelt1Motor" Type="Input" Address="I1.1" IsVirtual="true">
            <Pin Address="I1.2" Desc="Forward" />
            <Pin Address="I1.3" Desc="Backward" />
            <Select Value="1" Desc="stopped" Condition="Forward=0 AND Backward=0" />
            <Select Value="2" Desc="forward rotation" Condition="Forward=1 AND Backward=0" />
            <Select Value="3" Desc="backward rotation" Condition="Forward=0 AND Backward=1" />
        </Signal>
        <Signal Name="CB1Sensor1" Type="Input" Address="I2.6">
            <Select Value="1" Desc="triggered" />
            <Select Value="0" Desc="not triggered" />
        </Signal>
        <Signal Name="CB1Sensor2" Type="Input" Address="I2.7">
            <Select Value="1" Desc="triggered" />
            <Select Value="0" Desc="not triggered" />
        </Signal>
        <Signal Name="forward_conveyorBelt1" Type="Output" Address="Q0.0">
            <Select Value="1" Desc="forward" />
            <Select Value="0" Desc="stop" />
        </Signal>
        <Signal Name="backward_conveyorBelt1" Type="Output" Address="Q0.1">
            <Select Value="1" Desc="backward" />
            <Select Value="0" Desc="stop" />
        </Signal>
        <Signal Name="stop_conveyorBelt1" Type="Output" Address="Q0.2">
            <Select Value="1" Desc="stop" />
            <Select Value="0" Desc="idle" />
        </Signal>
    </Device>

